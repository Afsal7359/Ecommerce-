    "next": "14.2.0",
    "react": "^18",
    "react-dom": "^18",
    "lucide-react": "^0.383.0",
    "axios": "^1.6.2",
    "clsx": "^2.1.0",
    "js-cookie": "^3.0.5",
    "recharts": "^2.10.3",
    "react-hot-toast": "^2.4.1",
    "react-dropzone": "^14.2.3",
    "date-fns": "^3.0.6"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/js-cookie": "^3.0.6",
    "tailwindcss": "^3.4.0",
    "postcss": "^8",
    "autoprefixer": "^10",
    "eslint": "^8",
